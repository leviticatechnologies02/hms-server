# Application
APP_NAME=Levitica OneHealth
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:Harshi245@localhost:5432/levitica_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_SPECIAL=True
PASSWORD_REQUIRE_NUMBER=True
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
HASHING_ALGORITHM=argon2id

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# Super Admin
SUPER_ADMIN_EMAIL=admin@levitica.com
SUPER_ADMIN_PASSWORD=Admin@123456

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@levitica.com

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=levitica-files
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT_URL=http://localhost:9000